rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users collection ──
    // Authenticated users can read any profile; only owner can write
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;

      // ── Cart subcollection ──
      match /cart/{productId} {
        allow read, write: if request.auth != null
          && request.auth.uid == userId;
      }
    }

    // ── Products (Marketplace) ──
    match /products/{productId} {
      allow read: if request.auth != null;
      // Only company/seller can create their own products
      allow create: if request.auth != null
        && request.resource.data.sellerId == request.auth.uid;
      // Only the product owner can update/delete
      allow update, delete: if request.auth != null
        && resource.data.sellerId == request.auth.uid;
    }

    // ── Orders (Marketplace) ──
    match /orders/{orderId} {
      // Buyer can read their own orders
      allow read: if request.auth != null
        && (resource.data.buyerId == request.auth.uid || true);
        // NOTE: Seller needs to read orders containing their items.
        // For MVP, all authenticated users can read orders.
        // Tighten in Phase 2 with Cloud Functions.
      allow create: if request.auth != null
        && request.resource.data.buyerId == request.auth.uid;
      allow update: if request.auth != null;
        // Seller updates status — validated in app logic for MVP.
    }

    // ── Community Posts ──
    match /communityPosts/{postId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }

    // ── Comments ──
    match /comments/{commentId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }

    // ── Reported Posts ──
    match /reportedPosts/{reportId} {
      allow read: if false; // Admin only (future)
      allow create: if request.auth != null;
    }

    // ── Field Visits (Appointments) ──
    match /fieldVisits/{visitId} {
      allow read: if request.auth != null;
      // Farmer can create only their own visits
      allow create: if request.auth != null
        && request.resource.data.farmerId == request.auth.uid;
      // Expert can update only visits assigned to them
      allow update: if request.auth != null
        && (resource.data.expertId == request.auth.uid
            || resource.data.farmerId == request.auth.uid);
    }

    // ── Bookmarks subcollection ──
    match /communityPosts/{postId}/bookmarks/{userId} {
      allow read, write: if request.auth != null
        && request.auth.uid == userId;
    }

    // ── Saved Locations (Weather) ──
    match /users/{userId}/savedLocations/{locationId} {
      allow read, write: if request.auth != null
        && request.auth.uid == userId;
    }

    // ── Crops (Crop Recommendation) ──
    // All authenticated users can read crop data; no client writes
    match /crops/{cropId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── Crop Recommendations (History) ──
    // Users can read their own recommendations and create new ones
    match /cropRecommendations/{recId} {
      allow read: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
    }
  }
}

