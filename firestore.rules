rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users collection ──
    // Authenticated users can read any profile; only owner can write
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;

      // ── Cart subcollection ──
      match /cart/{productId} {
        allow read, write: if request.auth != null
          && request.auth.uid == userId;
      }
    }

    // ── Products (Marketplace) ──
    match /products/{productId} {
      allow read: if request.auth != null;
      // Only company/seller can create their own products
      allow create: if request.auth != null
        && request.resource.data.sellerId == request.auth.uid;
      // Only the product owner can update/delete
      allow update, delete: if request.auth != null
        && resource.data.sellerId == request.auth.uid;
    }

    // ── Orders (Marketplace) ──
    match /orders/{orderId} {
      // Buyer can read their own orders
      allow read: if request.auth != null
        && (resource.data.buyerId == request.auth.uid || true);
        // NOTE: Seller needs to read orders containing their items.
        // For MVP, all authenticated users can read orders.
        // Tighten in Phase 2 with Cloud Functions.
      allow create: if request.auth != null
        && request.resource.data.buyerId == request.auth.uid;
      allow update: if request.auth != null;
        // Seller updates status — validated in app logic for MVP.
    }

    // ── Community Posts ──
    match /communityPosts/{postId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }

    // ── Comments ──
    match /comments/{commentId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }

    // ── Reported Posts ──
    match /reportedPosts/{reportId} {
      allow read: if false; // Admin only (future)
      allow create: if request.auth != null;
    }

    // ── Field Visits (Appointments) ──
    match /fieldVisits/{visitId} {
      allow read: if request.auth != null;
      // Farmer can create only their own visits
      allow create: if request.auth != null
        && request.resource.data.farmerId == request.auth.uid;
      // Expert can update only visits assigned to them
      allow update: if request.auth != null
        && (resource.data.expertId == request.auth.uid
            || resource.data.farmerId == request.auth.uid);
    }

    // ── Bookmarks subcollection ──
    match /communityPosts/{postId}/bookmarks/{userId} {
      allow read, write: if request.auth != null
        && request.auth.uid == userId;
    }

    // ── Saved Locations (Weather) ──
    match /users/{userId}/savedLocations/{locationId} {
      allow read, write: if request.auth != null
        && request.auth.uid == userId;
    }

    // ── Crops (Crop Recommendation) ──
    // All authenticated users can read crop data; no client writes
    match /crops/{cropId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── Farmers (Anonymous Farmer Profiles) ──
    // Each farmer can only read and write their own document.
    // Used by FarmerAuthService for persistent session management.
    match /farmers/{uid} {
      allow read: if request.auth != null
        && request.auth.uid == uid;
      allow write: if request.auth != null
        && request.auth.uid == uid;
    }

    // ── Crop Recommendations (History) ──
    // Users can read their own recommendations and create new ones
    match /cropRecommendations/{recId} {
      allow read: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
    }

    // ── Disease Detection History ──
    // Users can read and save their own detection results in a subcollection
    match /farmers/{farmerId}/detectionHistory/{historyId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == farmerId;
    }

    // ── Consultation Appointments ──
    // Farmer creates their own appointment.
    // Expert can only update the 'status' field on their appointments.
    // Both parties can read; nobody can delete (status changes only).
    match /appointments/{appointmentId} {
      allow create: if request.auth != null
        && request.resource.data.farmerUid == request.auth.uid;

      allow update: if request.auth != null
        && (
          // Expert updates status only
          (resource.data.expertUid == request.auth.uid
           && request.resource.data.diff(resource.data)
                .affectedKeys().hasOnly(['status']))
          ||
          // Farmer cancels (status only) their own pending appointment
          (resource.data.farmerUid == request.auth.uid
           && resource.data.status == 'pending'
           && request.resource.data.diff(resource.data)
                .affectedKeys().hasOnly(['status'])
           && request.resource.data.status == 'cancelled')
        );

      allow read: if request.auth != null
        && (resource.data.farmerUid == request.auth.uid
         || resource.data.expertUid == request.auth.uid);

      allow delete: if false;
    }
  }
}

